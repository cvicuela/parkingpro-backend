# ==========================================
# ParkingPro Backend - Variables de Entorno
# ==========================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos PostgreSQL / Supabase
DATABASE_URL=postgresql://user:password@host:5432/parkingpro

# JWT
JWT_SECRET=tu-secreto-seguro-aqui
JWT_EXPIRES_IN=24h

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# ITBIS / Tasa de impuesto (18% RD)
TAX_RATE=0.18

# ── Parámetros antifraude y caja ──────────────────────────
CASH_DIFF_THRESHOLD=200
REFUND_LIMIT_OPERATOR=500
ALERT_EMAIL=alonsoveloz@gmail.com

# ── SMTP para alertas por email ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password

# ── Pasarelas de pago (opcional) ──────────────────────────
CARDNET_API_URL=
CARDNET_API_KEY=
STRIPE_SECRET_KEY=sk_test_your_key_here

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
